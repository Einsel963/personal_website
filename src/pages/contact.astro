---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile } from '../data/profile';

const maybeLink = (value: string) => /^https?:\/\//.test(value);
---

<BaseLayout title="Contact">
  <section class="page-intro">
    <p class="eyebrow">Contact</p>
    <h1>Get in Touch</h1>
    <p class="lead">
      Faculty members, students, and interested readers are welcome to contact
      me for academic discussions, suggestions, or possible research-related
      communication.
    </p>
  </section>

  <section class="card">
    <dl class="detail-list">
      <div>
        <dt>Email</dt>
        <dd>{profile.contact.email}</dd>
      </div>
      <div>
        <dt>GitHub</dt>
        <dd><a href={profile.contact.github}>{profile.contact.github}</a></dd>
      </div>
      <div>
        <dt>Google Scholar</dt>
        <dd>
          {maybeLink(profile.contact.scholar) ? (
            <a href={profile.contact.scholar}>{profile.contact.scholar}</a>
          ) : (
            profile.contact.scholar
          )}
        </dd>
      </div>
      <div>
        <dt>ORCID</dt>
        <dd>
          {maybeLink(profile.contact.orcid) ? (
            <a href={profile.contact.orcid}>{profile.contact.orcid}</a>
          ) : (
            profile.contact.orcid
          )}
        </dd>
      </div>
      <div>
        <dt>Location</dt>
        <dd>{profile.contact.location}</dd>
      </div>
    </dl>
  </section>
</BaseLayout>
