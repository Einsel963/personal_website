---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const rawTalks = (await getCollection('talks')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const rawNotes = (await getCollection('notes')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const talks = await Promise.all(
  rawTalks.map(async (entry) => {
    const { Content } = await entry.render();
    return { ...entry, Content };
  })
);

const notes = await Promise.all(
  rawNotes.map(async (entry) => {
    const { Content } = await entry.render();
    return { ...entry, Content };
  })
);

const availableNotes = notes.filter((note) => note.data.pdf);
const forthcomingNotes = notes.filter((note) => !note.data.pdf);
const availableTalks = talks.filter((talk) => talk.data.pdf);
const forthcomingTalks = talks.filter((talk) => !talk.data.pdf);
const withBase = (path: string) =>
  path.startsWith('/') ? `${import.meta.env.BASE_URL}${path.slice(1)}` : path;
---

<BaseLayout title="Notes & Talks">
  <section class="page-intro">
    <p class="eyebrow">Notes & Talks</p>
    <h1>Notes and Internal Presentations</h1>
    <p class="lead">
      This section collects selected notes from my studies and research work.
      The materials are meant to share my learning process, research progress,
      and partial reflections on topics that I am currently exploring.
    </p>
    <p>
      Many of these notes are works in progress and may contain mistakes or
      omissions. I welcome corrections, suggestions, and discussions from
      interested readers. Please feel free to contact me at MXY1963937485 [at]
      hotmail [dot] com.
    </p>
  </section>

  {availableNotes.length > 0 && (
    <section class="section">
      <h2>Available Notes</h2>
      <div class="stack">
        {availableNotes.map((entry) => (
          <article class="card">
            <h3>{entry.data.title}</h3>
            <p class="meta">
              {entry.data.year ?? entry.data.date.getFullYear()}
              {entry.data.status ? ` - ${entry.data.status}` : ''}
            </p>
            <p>
              <a
                class="button-link"
                href={withBase(entry.data.pdf)}
                target="_blank"
                rel="noopener noreferrer"
              >
                View PDF
              </a>
            </p>
            <div class="prose">
              <entry.Content />
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  {forthcomingNotes.length > 0 && (
    <section class="section">
      <h2>Forthcoming Notes</h2>
      <div class="stack">
        {forthcomingNotes.map((entry) => (
          <article class="card">
            <h3>{entry.data.title}</h3>
            <p class="meta">
              {entry.data.year ?? entry.data.date.getFullYear()}
              {entry.data.status ? ` - ${entry.data.status}` : ''}
            </p>
            <ul class="tag-list" aria-label="Availability">
              <li>Coming soon</li>
            </ul>
            <div class="prose">
              <entry.Content />
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  {availableTalks.length > 0 && (
    <section class="section">
      <h2>Available Talks</h2>
      <div class="stack">
        {availableTalks.map((entry) => (
          <article class="card">
            <h3>{entry.data.title}</h3>
            <p class="meta">
              {entry.data.event} - {entry.data.year ?? entry.data.date.getFullYear()}
              {entry.data.status ? ` - ${entry.data.status}` : ''}
            </p>
            <p>
              <a
                class="button-link"
                href={withBase(entry.data.pdf)}
                target="_blank"
                rel="noopener noreferrer"
              >
                View PDF
              </a>
            </p>
            <div class="prose">
              <entry.Content />
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  {forthcomingTalks.length > 0 && (
    <section class="section">
      <h2>Forthcoming Talks</h2>
      <div class="stack">
        {forthcomingTalks.map((entry) => (
          <article class="card">
            <h3>{entry.data.title}</h3>
            <p class="meta">
              {entry.data.event} - {entry.data.year ?? entry.data.date.getFullYear()}
              {entry.data.status ? ` - ${entry.data.status}` : ''}
            </p>
            <ul class="tag-list" aria-label="Availability">
              <li>Coming soon</li>
            </ul>
            <div class="prose">
              <entry.Content />
            </div>
          </article>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
